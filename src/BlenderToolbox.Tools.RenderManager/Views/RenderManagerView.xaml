<UserControl x:Class="BlenderToolbox.Tools.RenderManager.Views.RenderManagerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             HorizontalAlignment="Stretch"
             VerticalAlignment="Stretch"
             mc:Ignorable="d">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <Style x:Key="QueueHeaderTextStyle"
               TargetType="TextBlock"
               BasedOn="{StaticResource HelperTextStyle}">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource TextForegroundBrush}" />
        </Style>
        <Style x:Key="QueueTextBoxStyle"
               TargetType="TextBox"
               BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="MinWidth" Value="0" />
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="{DynamicResource InputBackgroundBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextForegroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource InputBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="ComboBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="{DynamicResource CornerRadiusControl}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="32" />
                                    </Grid.ColumnDefinitions>
                                    <ContentPresenter Grid.Column="0"
                                                      Margin="{TemplateBinding Padding}"
                                                      VerticalAlignment="Center"
                                                      HorizontalAlignment="Left"
                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"
                                                      RecognizesAccessKey="True"
                                                      TextElement.Foreground="{TemplateBinding Foreground}" />
                                    <Border Grid.Column="1"
                                            Background="Transparent">
                                        <Path Width="10"
                                              Height="6"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Fill="{TemplateBinding Foreground}"
                                              Data="M 0 0 L 5 6 L 10 0 Z" />
                                    </Border>
                                </Grid>
                            </Border>
                            <Popup x:Name="PART_Popup"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom">
                                <Border Margin="0,4,0,0"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                        Background="{DynamicResource InputBackgroundBrush}"
                                        BorderBrush="{DynamicResource InputBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="{DynamicResource CornerRadiusControl}">
                                    <ScrollViewer Margin="2"
                                                  SnapsToDevicePixels="True">
                                        <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained" />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="ComboBorder" Property="BorderBrush" Value="{DynamicResource PrimaryBrush}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ComboBorder" Property="BorderBrush" Value="{DynamicResource SidebarItemSelectedBorderBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ComboBorder" Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="{DynamicResource InputBackgroundBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextForegroundBrush}" />
            <Setter Property="Padding" Value="10,6" />
            <Style.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Background" Value="{DynamicResource SidebarItemHoverBrush}" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource SidebarItemSelectedBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="ProgressBar">
            <Setter Property="Minimum" Value="0" />
            <Setter Property="Maximum" Value="100" />
            <Setter Property="Height" Value="10" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}" />
            <Setter Property="Background" Value="{DynamicResource SidebarItemHoverBrush}" />
        </Style>
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="RowBackground" Value="Transparent" />
            <Setter Property="AlternatingRowBackground" Value="Transparent" />
            <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource PanelBorderBrush}" />
            <Setter Property="VerticalGridLinesBrush" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource TextForegroundBrush}" />
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{DynamicResource SidebarItemBackgroundBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource MutedForegroundBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="8,8" />
            <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridColumnHeader">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource SidebarItemSelectedBrush}" />
                </Trigger>
                <MultiTrigger>
                    <MultiTrigger.Conditions>
                        <Condition Property="IsMouseOver" Value="True" />
                        <Condition Property="IsSelected" Value="False" />
                    </MultiTrigger.Conditions>
                    <Setter Property="Background" Value="{DynamicResource SidebarItemHoverBrush}" />
                </MultiTrigger>
                <DataTrigger Binding="{Binding IsEnabled}" Value="False">
                    <Setter Property="Opacity" Value="0.45" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource TextForegroundBrush}" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="Foreground" Value="{DynamicResource TextForegroundBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="*" />
            <RowDefinition Height="12" />
            <RowDefinition Height="240" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Style="{StaticResource PanelCardStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.2*" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="1*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="12" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0"
                            Grid.Column="0">
                    <TextBlock Style="{StaticResource SectionTitleTextStyle}"
                               Text="Render Queue" />
                    <TextBlock Margin="0,6,0,0"
                               Style="{StaticResource HelperTextStyle}"
                               Text="{Binding CurrentRunStateText}" />
                    <TextBlock Margin="0,8,0,0"
                               Style="{StaticResource StatusMessageTextStyle}"
                               Tag="{Binding StatusTone}"
                               Text="{Binding StatusMessage}" />
                </StackPanel>

                <Grid Grid.Row="0"
                      Grid.Column="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Margin="0,8,12,0"
                               Style="{StaticResource FieldLabelTextStyle}"
                               Text="Blender" />
                    <TextBox Grid.Column="1"
                             Margin="0,0,8,0"
                             Style="{StaticResource QueueTextBoxStyle}"
                             Text="{Binding DefaultBlenderPath, UpdateSourceTrigger=PropertyChanged}" />
                    <Button Grid.Column="2"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Command="{Binding BrowseDefaultBlenderCommand}"
                            Content="Browse" />
                </Grid>

                <Grid Grid.Row="2"
                      Grid.Column="0"
                      Grid.ColumnSpan="3">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="8" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="8" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Grid.Column="0"
                               Style="{StaticResource QueueHeaderTextStyle}"
                               Text="Queue Progress" />
                    <TextBlock Grid.Row="0"
                               Grid.Column="1"
                               HorizontalAlignment="Right"
                               FontWeight="SemiBold"
                               Text="{Binding GlobalProgressValue, StringFormat={}{0:0}%}" />
                    <ProgressBar Grid.Row="2"
                                 Grid.Column="0"
                                 Grid.ColumnSpan="2"
                                 Value="{Binding GlobalProgressValue, Mode=OneWay}" />
                    <TextBlock Grid.Row="4"
                               Grid.Column="0"
                               Grid.ColumnSpan="2"
                               Style="{StaticResource HelperTextStyle}"
                               Text="{Binding GlobalProgressSummary}" />
                </Grid>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.7*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="1*" MinWidth="360" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Style="{StaticResource PanelCardStyle}"
                    Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0"
                                Margin="18,14,18,12">
                        <DockPanel LastChildFill="False">
                            <StackPanel DockPanel.Dock="Left">
                                <TextBlock Style="{StaticResource SectionTitleTextStyle}"
                                           Text="Jobs" />
                                <TextBlock Margin="0,4,0,0"
                                           Style="{StaticResource HelperTextStyle}"
                                           Text="{Binding QueueSummary}" />
                            </StackPanel>

                            <WrapPanel DockPanel.Dock="Right"
                                       Orientation="Horizontal">
                                <Button Margin="8,0,8,8"
                                        MinWidth="92"
                                        Style="{StaticResource PrimaryButtonStyle}"
                                        Command="{Binding StartQueueCommand}"
                                        Content="Start" />
                                <Button Margin="0,0,8,8"
                                        MinWidth="92"
                                        Style="{StaticResource DangerButtonStyle}"
                                        Command="{Binding StopQueueCommand}"
                                        Content="Stop" />
                                <Button Margin="0,0,0,8"
                                        MinWidth="92"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Command="{Binding ResumeQueueCommand}"
                                        Content="Resume" />
                            </WrapPanel>
                        </DockPanel>

                        <WrapPanel Margin="0,6,0,0"
                                   Orientation="Horizontal">
                            <Button Margin="0,0,8,8"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Command="{Binding AddBlendCommand}"
                                    Content="Add Blend" />
                            <Button Margin="0,0,8,8"
                                    Style="{StaticResource DangerButtonStyle}"
                                    Command="{Binding RemoveSelectedJobCommand}"
                                    Content="Remove" />
                            <Button Margin="0,0,8,8"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Command="{Binding MoveSelectedJobUpCommand}"
                                    Content="Move Up" />
                            <Button Margin="0,0,8,8"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Command="{Binding MoveSelectedJobDownCommand}"
                                    Content="Move Down" />
                        </WrapPanel>
                    </StackPanel>

                    <DataGrid Grid.Row="1"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              CanUserResizeColumns="True"
                              CanUserReorderColumns="False"
                              CanUserSortColumns="False"
                              SelectionMode="Single"
                              SelectionUnit="FullRow"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              IsReadOnly="True"
                              AllowDrop="True"
                              PreviewMouseLeftButtonDown="QueueGrid_PreviewMouseLeftButtonDown"
                              PreviewMouseMove="QueueGrid_PreviewMouseMove"
                              Drop="QueueGrid_Drop"
                              ItemsSource="{Binding Jobs}"
                              SelectedItem="{Binding SelectedJob, Mode=TwoWay}">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header=""
                                                    Width="36">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding IsEnabled, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTextColumn Header="Path"
                                                Width="1.4*"
                                                Binding="{Binding BlendDirectory, Mode=OneWay}" />
                            <DataGridTextColumn Header="Blend"
                                                Width="1*"
                                                Binding="{Binding BlendFileName, Mode=OneWay}" />
                            <DataGridTextColumn Header="Frames"
                                                Width="1.1*"
                                                Binding="{Binding FrameSummary, Mode=OneWay}" />
                            <DataGridTemplateColumn Header="Progress"
                                                    Width="1.3*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel VerticalAlignment="Center">
                                            <ProgressBar Value="{Binding ProgressValue, Mode=OneWay}"
                                                         Height="6" />
                                            <DockPanel Margin="0,3,0,0">
                                                <TextBlock DockPanel.Dock="Left"
                                                           Text="{Binding ProgressText}"
                                                           FontSize="11"
                                                           Foreground="{DynamicResource MutedForegroundBrush}" />
                                                <TextBlock DockPanel.Dock="Right"
                                                           HorizontalAlignment="Right"
                                                           Text="{Binding ProgressPercentLabel}"
                                                           FontWeight="SemiBold"
                                                           FontSize="11" />
                                            </DockPanel>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Status"
                                                Width="0.75*"
                                                Binding="{Binding Status, Mode=OneWay}" />
                            <DataGridTextColumn Header="ETA"
                                                Width="0.65*"
                                                Binding="{Binding EtaText, Mode=OneWay}" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <Border Grid.Column="2"
                    Style="{StaticResource PanelCardStyle}">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitleTextStyle}"
                                   Text="Selected Job" />
                        <TextBlock Margin="0,6,0,0"
                                   Style="{StaticResource HelperTextStyle}"
                                   Text="{Binding SelectedJobTitle}" />

                        <StackPanel Margin="0,16,0,0"
                                    DataContext="{Binding SelectedJob}"
                                    IsEnabled="{Binding DataContext.HasSelectedJob, RelativeSource={RelativeSource AncestorType=UserControl}}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <TextBox Grid.Column="0"
                                         Margin="0,0,8,0"
                                         Style="{StaticResource QueueTextBoxStyle}"
                                         Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" />
                                <CheckBox Grid.Column="1"
                                          Margin="0,0,8,0"
                                          VerticalAlignment="Center"
                                          Content="Enabled"
                                          IsChecked="{Binding IsEnabled}" />
                                <Button Grid.Column="2"
                                        Margin="0,0,8,0"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Command="{Binding DataContext.BrowseSelectedBlendCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        Content="Browse Blend" />
                                <Button Grid.Column="3"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Command="{Binding DataContext.ResetSelectedJobCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        Content="Reset Progress" />
                            </Grid>

                            <Border Margin="0,14,0,0"
                                    Padding="14"
                                    Background="{DynamicResource SidebarItemBackgroundBrush}"
                                    BorderBrush="{DynamicResource PanelBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource QueueHeaderTextStyle}"
                                                   Text="{Binding BlendFileName}" />
                                        <TextBlock Margin="0,6,0,0"
                                                   Style="{StaticResource HelperTextStyle}"
                                                   Text="{Binding BlendFilePath}" />
                                        <TextBlock Margin="0,8,0,0"
                                                   Style="{StaticResource HelperTextStyle}"
                                                   Text="{Binding InspectionSummary}" />
                                    </StackPanel>
                                    <Button Grid.Column="1"
                                            VerticalAlignment="Top"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Command="{Binding DataContext.InspectSelectedJobCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            Content="Reload .blend" />
                                </Grid>
                            </Border>

                            <Border Margin="0,18,0,0"
                                    Padding="14"
                                    Background="{DynamicResource SidebarItemBackgroundBrush}"
                                    BorderBrush="{DynamicResource PanelBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="12">
                                <StackPanel>
                                    <DockPanel>
                                        <TextBlock DockPanel.Dock="Left"
                                                   Style="{StaticResource SectionTitleTextStyle}"
                                                   Text="Latest Frame" />
                                        <TextBlock DockPanel.Dock="Right"
                                                   Margin="12,2,0,0"
                                                   Style="{StaticResource HelperTextStyle}"
                                                   Text="{Binding ProgressText}" />
                                    </DockPanel>

                                    <Border Margin="0,10,0,0"
                                            MinHeight="220"
                                            Background="{DynamicResource InputBackgroundBrush}"
                                            BorderBrush="{DynamicResource InputBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="10">
                                        <Grid>
                                            <Image Source="{Binding PreviewImageSource}"
                                                   Stretch="Uniform">
                                                <Image.Style>
                                                    <Style TargetType="Image">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HasPreviewImage}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Image.Style>
                                            </Image>

                                            <TextBlock Margin="24"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       Foreground="{DynamicResource MutedForegroundBrush}"
                                                       FontSize="12"
                                                       Text="{Binding PreviewStatusText}"
                                                       TextAlignment="Center"
                                                       TextWrapping="Wrap">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HasPreviewImage}" Value="True">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Grid>
                                    </Border>

                                    <TextBlock Margin="0,10,0,0"
                                               Style="{StaticResource HelperTextStyle}"
                                               Text="{Binding PreviewPathText}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>

                            <Border Margin="0,18,0,0"
                                    Padding="14"
                                    Background="{DynamicResource SidebarItemBackgroundBrush}"
                                    BorderBrush="{DynamicResource PanelBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="12">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource SectionTitleTextStyle}"
                                               Text="Mode" />
                                    <Grid Margin="0,10,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="8" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <CheckBox Grid.Column="0"
                                                  VerticalAlignment="Center"
                                                  IsChecked="{Binding HasFrameOverride, Mode=TwoWay}" />
                                        <TextBlock Grid.Column="2"
                                                   VerticalAlignment="Center"
                                                   Style="{StaticResource FieldLabelTextStyle}"
                                                   Text="Override frames" />
                                    </Grid>
                                    <ComboBox Margin="0,10,0,0"
                                              IsEnabled="{Binding HasFrameOverride}"
                                              ItemsSource="{Binding DataContext.FrameOverrideModes, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                              SelectedItem="{Binding Mode}" />
                                    <TextBlock Margin="0,6,0,0"
                                               Style="{StaticResource HelperTextStyle}"
                                               Text="{Binding BlendFrameSummary}" />

                                    <Grid Margin="0,12,0,0"
                                          IsEnabled="{Binding HasFrameOverride}"
                                          Visibility="{Binding IsFrameRangeMode, Converter={StaticResource BoolToVis}}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="8" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="8" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="4" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <TextBlock Grid.Column="0"
                                                   Style="{StaticResource HelperTextStyle}"
                                                   Text="Start" />
                                        <TextBlock Grid.Column="2"
                                                   Style="{StaticResource HelperTextStyle}"
                                                   Text="End" />
                                        <TextBlock Grid.Column="4"
                                                   Style="{StaticResource HelperTextStyle}"
                                                   Text="Step" />

                                        <TextBox Grid.Row="2"
                                                 Grid.Column="0"
                                                 Style="{StaticResource QueueTextBoxStyle}"
                                                 Text="{Binding StartFrame, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBox Grid.Row="2"
                                                 Grid.Column="2"
                                                 Style="{StaticResource QueueTextBoxStyle}"
                                                 Text="{Binding EndFrame, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBox Grid.Row="2"
                                                 Grid.Column="4"
                                                 Style="{StaticResource QueueTextBoxStyle}"
                                                 Text="{Binding Step, UpdateSourceTrigger=PropertyChanged}" />
                                    </Grid>

                                    <StackPanel Margin="0,12,0,0"
                                                IsEnabled="{Binding HasFrameOverride}"
                                                Visibility="{Binding IsSingleFrameMode, Converter={StaticResource BoolToVis}}">
                                        <TextBlock Style="{StaticResource HelperTextStyle}"
                                                   Text="Frame" />
                                        <TextBox Margin="0,4,0,0"
                                                 Style="{StaticResource QueueTextBoxStyle}"
                                                 Text="{Binding SingleFrame, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <Border Margin="0,18,0,0"
                                    Padding="14"
                                    Background="{DynamicResource SidebarItemBackgroundBrush}"
                                    BorderBrush="{DynamicResource PanelBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="12">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource SectionTitleTextStyle}"
                                               Text="Render Output" />

                                    <Grid Margin="0,10,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="8" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <CheckBox Grid.Column="0"
                                                  VerticalAlignment="Top"
                                                  IsChecked="{Binding HasOutputPathOverride, Mode=TwoWay}" />
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Style="{StaticResource FieldLabelTextStyle}"
                                                       Text="Output path" />
                                            <TextBox Margin="0,6,0,0"
                                                     IsEnabled="{Binding HasOutputPathOverride}"
                                                     Style="{StaticResource QueueTextBoxStyle}"
                                                     Text="{Binding OutputPathTemplate, UpdateSourceTrigger=PropertyChanged}" />
                                            <TextBlock Margin="0,6,0,0"
                                                       Style="{StaticResource HelperTextStyle}"
                                                       Text="{Binding OutputDirectoryHint}" />
                                        </StackPanel>
                                    </Grid>

                                    <Grid Margin="0,12,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="8" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <CheckBox Grid.Column="0"
                                                  VerticalAlignment="Top"
                                                  IsChecked="{Binding HasOutputNameOverride, Mode=TwoWay}" />
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Style="{StaticResource FieldLabelTextStyle}"
                                                       Text="Render name" />
                                            <TextBox Margin="0,6,0,0"
                                                     IsEnabled="{Binding HasOutputNameOverride}"
                                                     Style="{StaticResource QueueTextBoxStyle}"
                                                     Text="{Binding OutputFileNameTemplate, UpdateSourceTrigger=PropertyChanged}" />
                                            <TextBlock Margin="0,6,0,0"
                                                       Style="{StaticResource HelperTextStyle}"
                                                       Text="{Binding OutputNameHint}" />
                                        </StackPanel>
                                    </Grid>

                                    <Grid Margin="0,12,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="8" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <CheckBox Grid.Column="0"
                                                  VerticalAlignment="Top"
                                                  IsChecked="{Binding HasOutputFormatOverride, Mode=TwoWay}" />
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Style="{StaticResource FieldLabelTextStyle}"
                                                       Text="Format" />
                                            <ComboBox Margin="0,6,0,0"
                                                      IsEnabled="{Binding HasOutputFormatOverride}"
                                                      ItemsSource="{Binding DataContext.OutputFormats, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                      SelectedItem="{Binding OutputFormat, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                            <TextBlock Margin="0,6,0,0"
                                                       Style="{StaticResource HelperTextStyle}"
                                                       Text="{Binding OutputFormatHint}" />
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <Border Margin="0,18,0,0"
                                    Padding="14"
                                    Background="{DynamicResource SidebarItemBackgroundBrush}"
                                    BorderBrush="{DynamicResource PanelBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="12">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource SectionTitleTextStyle}"
                                               Text="Scene Settings" />

                                    <Grid Margin="0,10,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="8" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <CheckBox Grid.Column="0"
                                                  VerticalAlignment="Top"
                                                  IsChecked="{Binding HasSceneOverride, Mode=TwoWay}" />
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Style="{StaticResource FieldLabelTextStyle}"
                                                       Text="Scene" />
                                            <ComboBox Margin="0,6,0,0"
                                                      IsEnabled="{Binding HasSceneOverride}"
                                                      ItemsSource="{Binding AvailableSceneNames}"
                                                      SelectedItem="{Binding SceneName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                            <TextBlock Margin="0,6,0,0"
                                                       Style="{StaticResource HelperTextStyle}"
                                                       Text="{Binding SceneHint}" />
                                        </StackPanel>
                                    </Grid>

                                    <Grid Margin="0,12,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="8" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <CheckBox Grid.Column="0"
                                                  VerticalAlignment="Top"
                                                  IsChecked="{Binding HasCameraOverride, Mode=TwoWay}" />
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Style="{StaticResource FieldLabelTextStyle}"
                                                       Text="Camera" />
                                            <ComboBox Margin="0,6,0,0"
                                                      IsEnabled="{Binding HasCameraOverride}"
                                                      ItemsSource="{Binding AvailableCameraNames}"
                                                      SelectedItem="{Binding CameraName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                            <TextBlock Margin="0,6,0,0"
                                                       Style="{StaticResource HelperTextStyle}"
                                                       Text="{Binding CameraHint}" />
                                        </StackPanel>
                                    </Grid>

                                    <Grid Margin="0,12,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="8" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <CheckBox Grid.Column="0"
                                                  VerticalAlignment="Top"
                                                  IsChecked="{Binding HasViewLayerOverride, Mode=TwoWay}" />
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Style="{StaticResource FieldLabelTextStyle}"
                                                       Text="View Layer" />
                                            <ComboBox Margin="0,6,0,0"
                                                      IsEnabled="{Binding HasViewLayerOverride}"
                                                      ItemsSource="{Binding AvailableViewLayerNames}"
                                                      SelectedItem="{Binding ViewLayerName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                            <TextBlock Margin="0,6,0,0"
                                                       Style="{StaticResource HelperTextStyle}"
                                                       Text="{Binding ViewLayerHint}" />
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <Border Grid.Row="4"
                Style="{StaticResource PanelCardStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="12" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0">
                    <TextBlock DockPanel.Dock="Left"
                               Style="{StaticResource SectionTitleTextStyle}"
                               Text="Logs" />
                    <TextBlock DockPanel.Dock="Right"
                               Margin="12,2,0,0"
                               Style="{StaticResource HelperTextStyle}"
                               Text="{Binding SelectedJobTitle}" />
                </DockPanel>

                <TextBox x:Name="LogTextBox"
                         Grid.Row="2"
                         AcceptsReturn="True"
                         IsReadOnly="True"
                         Text="{Binding SelectedJobLogOutput, Mode=OneWay}"
                         TextChanged="LogTextBox_TextChanged"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto" />
            </Grid>
        </Border>
    </Grid>
</UserControl>

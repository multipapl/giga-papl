<UserControl x:Class="BlenderToolbox.Tools.RenderManager.Views.RenderManagerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             HorizontalAlignment="Stretch"
             VerticalAlignment="Stretch"
             mc:Ignorable="d">
    <UserControl.Resources>
        <Style x:Key="QueueHeaderTextStyle"
               TargetType="TextBlock"
               BasedOn="{StaticResource HelperTextStyle}">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource TextForegroundBrush}" />
        </Style>

        <Style x:Key="QueueCellTextStyle"
               TargetType="TextBlock"
               BasedOn="{StaticResource HelperTextStyle}">
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="StretchListBoxItemStyle"
               TargetType="ListBoxItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>

        <Style x:Key="QueueTextBoxStyle"
               TargetType="TextBox"
               BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="MinWidth" Value="0" />
        </Style>

        <Style TargetType="ProgressBar">
            <Setter Property="Minimum" Value="0" />
            <Setter Property="Maximum" Value="100" />
            <Setter Property="Height" Value="10" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}" />
            <Setter Property="Background" Value="{DynamicResource SidebarItemHoverBrush}" />
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="*" />
            <RowDefinition Height="12" />
            <RowDefinition Height="220" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Style="{StaticResource PanelCardStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="14" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="520" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Style="{StaticResource SectionTitleTextStyle}"
                                   Text="Render Queue" />
                        <TextBlock Margin="0,6,0,0"
                                   Style="{StaticResource HelperTextStyle}"
                                   Text="{Binding CurrentRunStateText}" />
                        <TextBlock Margin="0,8,0,0"
                                   Style="{StaticResource StatusMessageTextStyle}"
                                   Tag="{Binding StatusTone}"
                                   Text="{Binding StatusMessage}" />
                    </StackPanel>

                    <UniformGrid Grid.Column="2"
                                 Columns="4"
                                 Rows="2">
                        <Button Margin="0,0,10,10"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Command="{Binding AddBlendCommand}"
                                Content="Add Blend" />
                        <Button Margin="0,0,10,10"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Command="{Binding AddEmptyJobCommand}"
                                Content="Add Empty" />
                        <Button Margin="0,0,10,10"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Command="{Binding DuplicateSelectedJobCommand}"
                                Content="Duplicate" />
                        <Button Margin="0,0,0,10"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Command="{Binding ToggleSelectedJobEnabledCommand}"
                                Content="Enable / Disable" />
                        <Button Margin="0,0,10,0"
                                Style="{StaticResource DangerButtonStyle}"
                                Command="{Binding RemoveSelectedJobCommand}"
                                Content="Remove" />
                        <Button Margin="0,0,10,0"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Command="{Binding MoveSelectedJobUpCommand}"
                                Content="Move Up" />
                        <Button Margin="0,0,10,0"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Command="{Binding MoveSelectedJobDownCommand}"
                                Content="Move Down" />
                        <Button Margin="0"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Command="{Binding ToggleQueueRunCommand}"
                                Content="{Binding QueueRunButtonLabel}" />
                    </UniformGrid>
                </Grid>

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="8" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="8" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Grid.Column="0"
                               Style="{StaticResource QueueHeaderTextStyle}"
                               Text="Queue Progress" />
                    <TextBlock Grid.Row="0"
                               Grid.Column="1"
                               HorizontalAlignment="Right"
                               FontWeight="SemiBold"
                               Text="{Binding GlobalProgressValue, StringFormat={}{0:0}%}" />
                    <ProgressBar Grid.Row="2"
                                 Grid.Column="0"
                                 Grid.ColumnSpan="2"
                                 Value="{Binding GlobalProgressValue, Mode=OneWay}" />
                    <TextBlock Grid.Row="4"
                               Grid.Column="0"
                               Grid.ColumnSpan="2"
                               Style="{StaticResource HelperTextStyle}"
                               Text="{Binding GlobalProgressSummary}" />
                </Grid>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.7*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Style="{StaticResource PanelCardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="10" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0">
                        <TextBlock DockPanel.Dock="Left"
                                   Style="{StaticResource SectionTitleTextStyle}"
                                   Text="Jobs" />
                        <TextBlock DockPanel.Dock="Right"
                                   Margin="12,2,0,0"
                                   Style="{StaticResource HelperTextStyle}"
                                   Text="{Binding QueueSummary}" />
                    </DockPanel>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2.4*" MinWidth="180" />
                            <ColumnDefinition Width="1.25*" MinWidth="100" />
                            <ColumnDefinition Width="0.95*" MinWidth="78" />
                            <ColumnDefinition Width="1.3*" MinWidth="110" />
                            <ColumnDefinition Width="1.55*" MinWidth="150" />
                            <ColumnDefinition Width="0.95*" MinWidth="80" />
                            <ColumnDefinition Width="0.8*" MinWidth="60" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Style="{StaticResource QueueHeaderTextStyle}"
                                   Text="Path" />
                        <TextBlock Grid.Column="1"
                                   Style="{StaticResource QueueHeaderTextStyle}"
                                   Text="Blend" />
                        <TextBlock Grid.Column="2"
                                   Style="{StaticResource QueueHeaderTextStyle}"
                                   Text="Mode" />
                        <TextBlock Grid.Column="3"
                                   Style="{StaticResource QueueHeaderTextStyle}"
                                   Text="Frames" />
                        <TextBlock Grid.Column="4"
                                   Style="{StaticResource QueueHeaderTextStyle}"
                                   Text="Progress" />
                        <TextBlock Grid.Column="5"
                                   Style="{StaticResource QueueHeaderTextStyle}"
                                   Text="Status" />
                        <TextBlock Grid.Column="6"
                                   Style="{StaticResource QueueHeaderTextStyle}"
                                   Text="ETA" />
                    </Grid>

                    <ListBox Grid.Row="4"
                             ItemContainerStyle="{StaticResource StretchListBoxItemStyle}"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ItemsSource="{Binding Jobs}"
                             SelectedItem="{Binding SelectedJob}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="12"
                                        Background="{DynamicResource SidebarItemBackgroundBrush}"
                                        BorderBrush="{DynamicResource SidebarItemBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="{DynamicResource CornerRadiusPanel}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2.4*" MinWidth="180" />
                                            <ColumnDefinition Width="1.25*" MinWidth="100" />
                                            <ColumnDefinition Width="0.95*" MinWidth="78" />
                                            <ColumnDefinition Width="1.3*" MinWidth="110" />
                                            <ColumnDefinition Width="1.55*" MinWidth="150" />
                                            <ColumnDefinition Width="0.95*" MinWidth="80" />
                                            <ColumnDefinition Width="0.8*" MinWidth="60" />
                                        </Grid.ColumnDefinitions>

                                        <DockPanel Grid.Column="0"
                                                   LastChildFill="True">
                                            <CheckBox DockPanel.Dock="Left"
                                                      Margin="0,0,8,0"
                                                      VerticalAlignment="Center"
                                                      IsChecked="{Binding IsEnabled}" />
                                            <TextBlock Style="{StaticResource QueueCellTextStyle}"
                                                       Text="{Binding BlendDirectory}" />
                                        </DockPanel>

                                        <StackPanel Grid.Column="1">
                                            <TextBlock Style="{StaticResource QueueCellTextStyle}"
                                                       FontWeight="SemiBold"
                                                       Text="{Binding BlendFileName}" />
                                            <TextBlock Margin="0,3,0,0"
                                                       Style="{StaticResource QueueCellTextStyle}"
                                                       Text="{Binding EffectiveName}" />
                                        </StackPanel>

                                        <TextBlock Grid.Column="2"
                                                   Style="{StaticResource QueueCellTextStyle}"
                                                   Text="{Binding Mode}" />
                                        <TextBlock Grid.Column="3"
                                                   Style="{StaticResource QueueCellTextStyle}"
                                                   Text="{Binding FrameSummary}" />

                                        <StackPanel Grid.Column="4">
                                            <ProgressBar Value="{Binding ProgressValue}" />
                                            <DockPanel Margin="0,4,0,0">
                                                <TextBlock DockPanel.Dock="Left"
                                                           Style="{StaticResource QueueCellTextStyle}"
                                                           Text="{Binding ProgressText}" />
                                                <TextBlock DockPanel.Dock="Right"
                                                           FontWeight="SemiBold"
                                                           Text="{Binding ProgressPercentLabel}" />
                                            </DockPanel>
                                        </StackPanel>

                                        <TextBlock Grid.Column="5"
                                                   Style="{StaticResource QueueCellTextStyle}"
                                                   Text="{Binding Status}" />
                                        <TextBlock Grid.Column="6"
                                                   Style="{StaticResource QueueCellTextStyle}"
                                                   Text="{Binding EtaText}" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <Border Grid.Column="2"
                    Style="{StaticResource PanelCardStyle}">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitleTextStyle}"
                                   Text="Selected Job" />
                        <TextBlock Margin="0,6,0,0"
                                   Style="{StaticResource HelperTextStyle}"
                                   Text="{Binding SelectedJobTitle}" />

                        <Grid Margin="0,16,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="132" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="88" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0"
                                       Margin="0,8,0,0"
                                       Style="{StaticResource FieldLabelTextStyle}"
                                       Text="Default Blender" />
                            <TextBox Grid.Row="0"
                                     Grid.Column="1"
                                     Margin="0,0,10,0"
                                     Style="{StaticResource QueueTextBoxStyle}"
                                     Text="{Binding DefaultBlenderPath, UpdateSourceTrigger=PropertyChanged}" />
                            <Button Grid.Row="0"
                                    Grid.Column="2"
                                    MinWidth="92"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Command="{Binding BrowseDefaultBlenderCommand}"
                                    Content="Browse" />

                            <TextBlock Grid.Row="1"
                                       Margin="0,22,0,0"
                                       Style="{StaticResource FieldLabelTextStyle}"
                                       Text="Output path" />
                            <TextBox Grid.Row="1"
                                     Grid.Column="1"
                                     Grid.ColumnSpan="2"
                                     Margin="0,14,0,0"
                                     Style="{StaticResource QueueTextBoxStyle}"
                                     Text="{Binding DefaultOutputPathTemplate, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Grid.Row="2"
                                       Margin="0,22,0,0"
                                       Style="{StaticResource FieldLabelTextStyle}"
                                       Text="File naming" />
                            <TextBox Grid.Row="2"
                                     Grid.Column="1"
                                     Grid.ColumnSpan="2"
                                     Margin="0,14,0,0"
                                     Style="{StaticResource QueueTextBoxStyle}"
                                     Text="{Binding DefaultOutputFileNameTemplate, UpdateSourceTrigger=PropertyChanged}" />
                        </Grid>

                        <CheckBox Margin="132,12,0,0"
                                  Content="Auto-inspect new jobs later"
                                  IsChecked="{Binding AutoInspectOnAdd}" />

                        <Grid Margin="0,18,0,0"
                              DataContext="{Binding SelectedJob}"
                              IsEnabled="{Binding DataContext.HasSelectedJob, RelativeSource={RelativeSource AncestorType=UserControl}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="132" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="96" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Margin="0,8,0,0"
                                       Style="{StaticResource FieldLabelTextStyle}"
                                       Text="Job name" />
                            <TextBox Grid.Column="1"
                                     Margin="0,0,10,0"
                                     Style="{StaticResource QueueTextBoxStyle}"
                                     Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" />
                            <CheckBox Grid.Column="2"
                                      VerticalAlignment="Center"
                                      Content="Enabled"
                                      IsChecked="{Binding IsEnabled}" />

                            <TextBlock Grid.Row="1"
                                       Margin="0,22,0,0"
                                       Style="{StaticResource FieldLabelTextStyle}"
                                       Text="Blend file" />
                            <TextBox Grid.Row="1"
                                     Grid.Column="1"
                                     Margin="0,14,10,0"
                                     Style="{StaticResource QueueTextBoxStyle}"
                                     Text="{Binding BlendFilePath, UpdateSourceTrigger=PropertyChanged}" />
                            <Button Grid.Row="1"
                                    Grid.Column="2"
                                    Margin="0,14,0,0"
                                    MinWidth="92"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Command="{Binding DataContext.BrowseSelectedBlendCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    Content="Browse" />

                            <TextBlock Grid.Row="2"
                                       Margin="0,22,0,0"
                                       Style="{StaticResource FieldLabelTextStyle}"
                                       Text="Blender exe" />
                            <TextBox Grid.Row="2"
                                     Grid.Column="1"
                                     Margin="0,14,10,0"
                                     Style="{StaticResource QueueTextBoxStyle}"
                                     Text="{Binding BlenderExecutablePath, UpdateSourceTrigger=PropertyChanged}" />
                            <Button Grid.Row="2"
                                    Grid.Column="2"
                                    Margin="0,14,0,0"
                                    MinWidth="110"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Command="{Binding DataContext.UseDefaultBlenderForSelectedJobCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    Content="Use Default" />

                            <TextBlock Grid.Row="3"
                                       Margin="0,22,0,0"
                                       Style="{StaticResource FieldLabelTextStyle}"
                                       Text="Mode" />
                            <ComboBox Grid.Row="3"
                                      Grid.Column="1"
                                      Grid.ColumnSpan="2"
                                      Margin="0,14,0,0"
                                      ItemsSource="{Binding DataContext.RenderModes, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                      SelectedItem="{Binding Mode}" />

                            <TextBlock Grid.Row="4"
                                       Margin="0,22,0,0"
                                       Style="{StaticResource FieldLabelTextStyle}"
                                       Text="Frames" />
                            <StackPanel Grid.Row="4"
                                        Grid.Column="1"
                                        Grid.ColumnSpan="2"
                                        Margin="0,14,0,0">
                                <UniformGrid Columns="4">
                                    <TextBox Margin="0,0,8,0"
                                             Style="{StaticResource QueueTextBoxStyle}"
                                             Text="{Binding StartFrame, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBox Margin="0,0,8,0"
                                             Style="{StaticResource QueueTextBoxStyle}"
                                             Text="{Binding EndFrame, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBox Margin="0,0,8,0"
                                             Style="{StaticResource QueueTextBoxStyle}"
                                             Text="{Binding Step, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBox Style="{StaticResource QueueTextBoxStyle}"
                                             Text="{Binding SingleFrame, UpdateSourceTrigger=PropertyChanged}" />
                                </UniformGrid>
                                <TextBlock Margin="0,8,0,0"
                                           Style="{StaticResource HelperTextStyle}"
                                           Text="{Binding FrameSummary}" />
                            </StackPanel>

                            <TextBlock Grid.Row="5"
                                       Margin="0,22,0,0"
                                       Style="{StaticResource FieldLabelTextStyle}"
                                       Text="Targets" />
                            <StackPanel Grid.Row="5"
                                        Grid.Column="1"
                                        Grid.ColumnSpan="2"
                                        Margin="0,14,0,0">
                                <UniformGrid Columns="3">
                                    <TextBox Margin="0,0,8,0"
                                             Style="{StaticResource QueueTextBoxStyle}"
                                             Text="{Binding SceneName, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBox Margin="0,0,8,0"
                                             Style="{StaticResource QueueTextBoxStyle}"
                                             Text="{Binding CameraName, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBox Style="{StaticResource QueueTextBoxStyle}"
                                             Text="{Binding ViewLayerName, UpdateSourceTrigger=PropertyChanged}" />
                                </UniformGrid>
                                <TextBox Margin="0,12,0,0"
                                         Style="{StaticResource QueueTextBoxStyle}"
                                         Text="{Binding CollectionOverrides, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Margin="0,8,0,0"
                                           Style="{StaticResource HelperTextStyle}"
                                           Text="{Binding TargetSummary}" />
                            </StackPanel>

                            <TextBlock Grid.Row="6"
                                       Margin="0,22,0,0"
                                       Style="{StaticResource FieldLabelTextStyle}"
                                       Text="Output + args" />
                            <StackPanel Grid.Row="6"
                                        Grid.Column="1"
                                        Grid.ColumnSpan="2"
                                        Margin="0,14,0,0">
                                <TextBox Style="{StaticResource QueueTextBoxStyle}"
                                         Text="{Binding OutputPathTemplate, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBox Margin="0,12,0,0"
                                         Style="{StaticResource QueueTextBoxStyle}"
                                         Text="{Binding OutputFileNameTemplate, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBox Margin="0,12,0,0"
                                         Style="{StaticResource QueueTextBoxStyle}"
                                         Text="{Binding ExtraArgs, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>

                            <TextBlock Grid.Row="7"
                                       Margin="0,22,0,0"
                                       Style="{StaticResource FieldLabelTextStyle}"
                                       Text="Job progress" />
                            <StackPanel Grid.Row="7"
                                        Grid.Column="1"
                                        Grid.ColumnSpan="2"
                                        Margin="0,14,0,0">
                                <ProgressBar Value="{Binding ProgressValue}" />
                                <DockPanel Margin="0,8,0,0">
                                    <TextBlock DockPanel.Dock="Left"
                                               Style="{StaticResource HelperTextStyle}"
                                               Text="{Binding ProgressText}" />
                                    <TextBlock DockPanel.Dock="Right"
                                               HorizontalAlignment="Right"
                                               FontWeight="SemiBold"
                                               Text="{Binding ProgressPercentLabel}" />
                                </DockPanel>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <Border Grid.Row="4"
                Style="{StaticResource PanelCardStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="12" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0">
                    <TextBlock DockPanel.Dock="Left"
                               Style="{StaticResource SectionTitleTextStyle}"
                               Text="Command And Logs" />
                    <TextBlock DockPanel.Dock="Right"
                               Margin="12,2,0,0"
                               Style="{StaticResource HelperTextStyle}"
                               Text="{Binding SelectedJobTitle}" />
                </DockPanel>

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="1.25*" />
                    </Grid.ColumnDefinitions>

                    <TextBox Grid.Column="0"
                             IsReadOnly="True"
                             Text="{Binding SelectedJobCommandPreview, Mode=OneWay}"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto" />
                    <TextBox Grid.Column="2"
                             AcceptsReturn="True"
                             IsReadOnly="True"
                             Text="{Binding SelectedJobLogOutput, Mode=OneWay}"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto" />
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>

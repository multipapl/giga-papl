<UserControl x:Class="BlenderToolbox.Tools.RenderManager.Views.RenderManagerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             HorizontalAlignment="Stretch"
             VerticalAlignment="Stretch"
             mc:Ignorable="d">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <Style x:Key="QueueHeaderTextStyle"
               TargetType="TextBlock"
               BasedOn="{StaticResource HelperTextStyle}">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource TextForegroundBrush}" />
        </Style>

        <Style x:Key="QueueTextBoxStyle"
               TargetType="TextBox"
               BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="MinWidth" Value="0" />
        </Style>

        <Style TargetType="ProgressBar">
            <Setter Property="Minimum" Value="0" />
            <Setter Property="Maximum" Value="100" />
            <Setter Property="Height" Value="10" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}" />
            <Setter Property="Background" Value="{DynamicResource SidebarItemHoverBrush}" />
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="RowBackground" Value="Transparent" />
            <Setter Property="AlternatingRowBackground" Value="Transparent" />
            <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource PanelBorderBrush}" />
            <Setter Property="VerticalGridLinesBrush" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource TextForegroundBrush}" />
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{DynamicResource SidebarItemBackgroundBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource MutedForegroundBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="8,8" />
            <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridColumnHeader">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource SidebarItemSelectedBrush}" />
                </Trigger>
                <MultiTrigger>
                    <MultiTrigger.Conditions>
                        <Condition Property="IsMouseOver" Value="True" />
                        <Condition Property="IsSelected" Value="False" />
                    </MultiTrigger.Conditions>
                    <Setter Property="Background" Value="{DynamicResource SidebarItemHoverBrush}" />
                </MultiTrigger>
                <DataTrigger Binding="{Binding IsEnabled}" Value="False">
                    <Setter Property="Opacity" Value="0.45" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource TextForegroundBrush}" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="Foreground" Value="{DynamicResource TextForegroundBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="*" />
            <RowDefinition Height="12" />
            <RowDefinition Height="220" />
        </Grid.RowDefinitions>

        <!-- Toolbar + global progress -->
        <Border Grid.Row="0"
                Style="{StaticResource PanelCardStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="14" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Style="{StaticResource SectionTitleTextStyle}"
                                   Text="Render Queue" />
                        <TextBlock Margin="0,6,0,0"
                                   Style="{StaticResource HelperTextStyle}"
                                   Text="{Binding CurrentRunStateText}" />
                        <TextBlock Margin="0,8,0,0"
                                   Style="{StaticResource StatusMessageTextStyle}"
                                   Tag="{Binding StatusTone}"
                                   Text="{Binding StatusMessage}" />
                    </StackPanel>

                    <WrapPanel Grid.Column="2"
                               Orientation="Horizontal"
                               VerticalAlignment="Top">
                        <Button Margin="0,0,8,8"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Command="{Binding AddBlendCommand}"
                                Content="Add Blend" />
                        <Button Margin="0,0,8,8"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Command="{Binding DuplicateSelectedJobCommand}"
                                Content="Duplicate" />
                        <Button Margin="0,0,8,8"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Command="{Binding ResetSelectedJobCommand}"
                                Content="Reset" />
                        <Button Margin="0,0,8,8"
                                Style="{StaticResource DangerButtonStyle}"
                                Command="{Binding RemoveSelectedJobCommand}"
                                Content="Remove" />
                        <Button Margin="0"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Command="{Binding ToggleQueueRunCommand}"
                                Content="{Binding QueueRunButtonLabel}" />
                    </WrapPanel>
                </Grid>

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="8" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="8" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Grid.Column="0"
                               Style="{StaticResource QueueHeaderTextStyle}"
                               Text="Queue Progress" />
                    <TextBlock Grid.Row="0"
                               Grid.Column="1"
                               HorizontalAlignment="Right"
                               FontWeight="SemiBold"
                               Text="{Binding GlobalProgressValue, StringFormat={}{0:0}%}" />
                    <ProgressBar Grid.Row="2"
                                 Grid.Column="0"
                                 Grid.ColumnSpan="2"
                                 Value="{Binding GlobalProgressValue, Mode=OneWay}" />
                    <TextBlock Grid.Row="4"
                               Grid.Column="0"
                               Grid.ColumnSpan="2"
                               Style="{StaticResource HelperTextStyle}"
                               Text="{Binding GlobalProgressSummary}" />
                </Grid>
            </Grid>
        </Border>

        <!-- Queue + Details -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.7*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="1*" MinWidth="320" />
            </Grid.ColumnDefinitions>

            <!-- Queue DataGrid -->
            <Border Grid.Column="0"
                    Style="{StaticResource PanelCardStyle}"
                    Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0"
                               Margin="18,14,18,10">
                        <TextBlock DockPanel.Dock="Left"
                                   Style="{StaticResource SectionTitleTextStyle}"
                                   Text="Jobs" />
                        <TextBlock DockPanel.Dock="Right"
                                   Margin="12,2,0,0"
                                   Style="{StaticResource HelperTextStyle}"
                                   Text="{Binding QueueSummary}" />
                    </DockPanel>

                    <DataGrid Grid.Row="1"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              CanUserResizeColumns="True"
                              CanUserReorderColumns="False"
                              CanUserSortColumns="False"
                              SelectionMode="Single"
                              SelectionUnit="FullRow"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              IsReadOnly="True"
                              AllowDrop="True"
                              PreviewMouseLeftButtonDown="QueueGrid_PreviewMouseLeftButtonDown"
                              PreviewMouseMove="QueueGrid_PreviewMouseMove"
                              Drop="QueueGrid_Drop"
                              ItemsSource="{Binding Jobs}"
                              SelectedItem="{Binding SelectedJob, Mode=TwoWay}">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header=""
                                                    Width="36">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding IsEnabled, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTextColumn Header="Path"
                                                Width="1.4*"
                                                Binding="{Binding BlendDirectory, Mode=OneWay}">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                                        <Setter Property="Foreground" Value="{DynamicResource MutedForegroundBrush}" />
                                        <Setter Property="VerticalAlignment" Value="Center" />
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="Blend"
                                                Width="1*"
                                                Binding="{Binding BlendFileName, Mode=OneWay}">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontWeight" Value="SemiBold" />
                                        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                                        <Setter Property="VerticalAlignment" Value="Center" />
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="Mode"
                                                Width="0.7*"
                                                Binding="{Binding Mode, Mode=OneWay}">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="VerticalAlignment" Value="Center" />
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="Frames"
                                                Width="0.9*"
                                                Binding="{Binding FrameSummary, Mode=OneWay}">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                                        <Setter Property="VerticalAlignment" Value="Center" />
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTemplateColumn Header="Progress"
                                                    Width="1.3*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel VerticalAlignment="Center">
                                            <ProgressBar Value="{Binding ProgressValue, Mode=OneWay}"
                                                         Height="6" />
                                            <DockPanel Margin="0,3,0,0">
                                                <TextBlock DockPanel.Dock="Left"
                                                           Text="{Binding ProgressText}"
                                                           FontSize="11"
                                                           Foreground="{DynamicResource MutedForegroundBrush}" />
                                                <TextBlock DockPanel.Dock="Right"
                                                           HorizontalAlignment="Right"
                                                           Text="{Binding ProgressPercentLabel}"
                                                           FontWeight="SemiBold"
                                                           FontSize="11" />
                                            </DockPanel>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTextColumn Header="Status"
                                                Width="0.7*"
                                                Binding="{Binding Status, Mode=OneWay}">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="VerticalAlignment" Value="Center" />
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="ETA"
                                                Width="0.6*"
                                                Binding="{Binding EtaText, Mode=OneWay}">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{DynamicResource MutedForegroundBrush}" />
                                        <Setter Property="VerticalAlignment" Value="Center" />
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- Details panel -->
            <Border Grid.Column="2"
                    Style="{StaticResource PanelCardStyle}">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitleTextStyle}"
                                   Text="Selected Job" />
                        <TextBlock Margin="0,6,0,0"
                                   Style="{StaticResource HelperTextStyle}"
                                   Text="{Binding SelectedJobTitle}" />

                        <!-- Global defaults -->
                        <Grid Margin="0,16,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0"
                                       Margin="0,8,0,0"
                                       Style="{StaticResource FieldLabelTextStyle}"
                                       Text="Default Blender" />
                            <TextBox Grid.Row="0"
                                     Grid.Column="1"
                                     Margin="0,0,8,0"
                                     Style="{StaticResource QueueTextBoxStyle}"
                                     Text="{Binding DefaultBlenderPath, UpdateSourceTrigger=PropertyChanged}" />
                            <Button Grid.Row="0"
                                    Grid.Column="2"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Command="{Binding BrowseDefaultBlenderCommand}"
                                    Content="Browse" />

                            <TextBlock Grid.Row="1"
                                       Margin="0,14,0,0"
                                       Style="{StaticResource FieldLabelTextStyle}"
                                       Text="Output path" />
                            <TextBox Grid.Row="1"
                                     Grid.Column="1"
                                     Grid.ColumnSpan="2"
                                     Margin="0,8,0,0"
                                     Style="{StaticResource QueueTextBoxStyle}"
                                     Text="{Binding DefaultOutputPathTemplate, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Grid.Row="2"
                                       Margin="0,14,0,0"
                                       Style="{StaticResource FieldLabelTextStyle}"
                                       Text="File naming" />
                            <TextBox Grid.Row="2"
                                     Grid.Column="1"
                                     Grid.ColumnSpan="2"
                                     Margin="0,8,0,0"
                                     Style="{StaticResource QueueTextBoxStyle}"
                                     Text="{Binding DefaultOutputFileNameTemplate, UpdateSourceTrigger=PropertyChanged}" />
                        </Grid>

                        <!-- Per-job fields -->
                        <Grid Margin="0,18,0,0"
                              DataContext="{Binding SelectedJob}"
                              IsEnabled="{Binding DataContext.HasSelectedJob, RelativeSource={RelativeSource AncestorType=UserControl}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <!-- Job name -->
                            <TextBlock Margin="0,8,0,0"
                                       Style="{StaticResource FieldLabelTextStyle}"
                                       Text="Job name" />
                            <TextBox Grid.Column="1"
                                     Margin="0,0,8,0"
                                     Style="{StaticResource QueueTextBoxStyle}"
                                     Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" />
                            <CheckBox Grid.Column="2"
                                      VerticalAlignment="Center"
                                      Content="Enabled"
                                      IsChecked="{Binding IsEnabled}" />

                            <!-- Blend file -->
                            <TextBlock Grid.Row="1"
                                       Margin="0,14,0,0"
                                       Style="{StaticResource FieldLabelTextStyle}"
                                       Text="Blend file" />
                            <TextBox Grid.Row="1"
                                     Grid.Column="1"
                                     Margin="0,8,8,0"
                                     Style="{StaticResource QueueTextBoxStyle}"
                                     Text="{Binding BlendFilePath, UpdateSourceTrigger=PropertyChanged}" />
                            <Button Grid.Row="1"
                                    Grid.Column="2"
                                    Margin="0,8,0,0"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Command="{Binding DataContext.BrowseSelectedBlendCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    Content="Browse" />

                            <!-- Blender exe -->
                            <TextBlock Grid.Row="2"
                                       Margin="0,14,0,0"
                                       Style="{StaticResource FieldLabelTextStyle}"
                                       Text="Blender exe" />
                            <TextBox Grid.Row="2"
                                     Grid.Column="1"
                                     Margin="0,8,8,0"
                                     Style="{StaticResource QueueTextBoxStyle}"
                                     Text="{Binding BlenderExecutablePath, UpdateSourceTrigger=PropertyChanged}" />
                            <Button Grid.Row="2"
                                    Grid.Column="2"
                                    Margin="0,8,0,0"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Command="{Binding DataContext.UseDefaultBlenderForSelectedJobCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    Content="Use Default" />

                            <!-- Mode -->
                            <TextBlock Grid.Row="3"
                                       Margin="0,14,0,0"
                                       Style="{StaticResource FieldLabelTextStyle}"
                                       Text="Mode" />
                            <ComboBox Grid.Row="3"
                                      Grid.Column="1"
                                      Grid.ColumnSpan="2"
                                      Margin="0,8,0,0"
                                      ItemsSource="{Binding DataContext.RenderModes, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                      SelectedItem="{Binding Mode}" />

                            <!-- Frames: conditional per mode -->
                            <TextBlock Grid.Row="4"
                                       Margin="0,14,0,0"
                                       Style="{StaticResource FieldLabelTextStyle}"
                                       Text="Frames" />
                            <StackPanel Grid.Row="4"
                                        Grid.Column="1"
                                        Grid.ColumnSpan="2"
                                        Margin="0,8,0,0">
                                <!-- Animation: hint only -->
                                <TextBlock Style="{StaticResource HelperTextStyle}"
                                           Text="Animation uses the scene frame range."
                                           Visibility="{Binding IsAnimationMode, Converter={StaticResource BoolToVis}}" />

                                <!-- FrameRange: start, end, step -->
                                <StackPanel Visibility="{Binding IsFrameRangeMode, Converter={StaticResource BoolToVis}}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="8" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="8" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="4" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <TextBlock Grid.Column="0"
                                                   Style="{StaticResource HelperTextStyle}"
                                                   Text="Start" />
                                        <TextBlock Grid.Column="2"
                                                   Style="{StaticResource HelperTextStyle}"
                                                   Text="End" />
                                        <TextBlock Grid.Column="4"
                                                   Style="{StaticResource HelperTextStyle}"
                                                   Text="Step" />

                                        <TextBox Grid.Row="2"
                                                 Grid.Column="0"
                                                 Style="{StaticResource QueueTextBoxStyle}"
                                                 Text="{Binding StartFrame, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBox Grid.Row="2"
                                                 Grid.Column="2"
                                                 Style="{StaticResource QueueTextBoxStyle}"
                                                 Text="{Binding EndFrame, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBox Grid.Row="2"
                                                 Grid.Column="4"
                                                 Style="{StaticResource QueueTextBoxStyle}"
                                                 Text="{Binding Step, UpdateSourceTrigger=PropertyChanged}" />
                                    </Grid>
                                </StackPanel>

                                <!-- SingleFrame: one field -->
                                <StackPanel Visibility="{Binding IsSingleFrameMode, Converter={StaticResource BoolToVis}}">
                                    <TextBlock Style="{StaticResource HelperTextStyle}"
                                               Text="Frame" />
                                    <TextBox Margin="0,4,0,0"
                                             Style="{StaticResource QueueTextBoxStyle}"
                                             Text="{Binding SingleFrame, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>

                                <TextBlock Margin="0,6,0,0"
                                           Style="{StaticResource HelperTextStyle}"
                                           Text="{Binding FrameSummary}" />
                            </StackPanel>

                            <!-- Targets -->
                            <TextBlock Grid.Row="5"
                                       Margin="0,14,0,0"
                                       Style="{StaticResource FieldLabelTextStyle}"
                                       Text="Targets" />
                            <StackPanel Grid.Row="5"
                                        Grid.Column="1"
                                        Grid.ColumnSpan="2"
                                        Margin="0,8,0,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="4" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Column="0"
                                               Style="{StaticResource HelperTextStyle}"
                                               Text="Scene" />
                                    <TextBlock Grid.Column="2"
                                               Style="{StaticResource HelperTextStyle}"
                                               Text="Camera" />
                                    <TextBlock Grid.Column="4"
                                               Style="{StaticResource HelperTextStyle}"
                                               Text="View Layer" />

                                    <TextBox Grid.Row="2"
                                             Grid.Column="0"
                                             Style="{StaticResource QueueTextBoxStyle}"
                                             Text="{Binding SceneName, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBox Grid.Row="2"
                                             Grid.Column="2"
                                             Style="{StaticResource QueueTextBoxStyle}"
                                             Text="{Binding CameraName, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBox Grid.Row="2"
                                             Grid.Column="4"
                                             Style="{StaticResource QueueTextBoxStyle}"
                                             Text="{Binding ViewLayerName, UpdateSourceTrigger=PropertyChanged}" />
                                </Grid>
                                <TextBox Margin="0,8,0,0"
                                         Style="{StaticResource QueueTextBoxStyle}"
                                         Text="{Binding CollectionOverrides, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Margin="0,6,0,0"
                                           Style="{StaticResource HelperTextStyle}"
                                           Text="{Binding TargetSummary}" />
                            </StackPanel>

                            <!-- Output + args -->
                            <TextBlock Grid.Row="6"
                                       Margin="0,14,0,0"
                                       Style="{StaticResource FieldLabelTextStyle}"
                                       Text="Output + args" />
                            <StackPanel Grid.Row="6"
                                        Grid.Column="1"
                                        Grid.ColumnSpan="2"
                                        Margin="0,8,0,0">
                                <TextBox Style="{StaticResource QueueTextBoxStyle}"
                                         Text="{Binding OutputPathTemplate, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBox Margin="0,8,0,0"
                                         Style="{StaticResource QueueTextBoxStyle}"
                                         Text="{Binding OutputFileNameTemplate, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBox Margin="0,8,0,0"
                                         Style="{StaticResource QueueTextBoxStyle}"
                                         Text="{Binding ExtraArgs, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>

                            <!-- Job progress -->
                            <TextBlock Grid.Row="7"
                                       Margin="0,14,0,0"
                                       Style="{StaticResource FieldLabelTextStyle}"
                                       Text="Job progress" />
                            <StackPanel Grid.Row="7"
                                        Grid.Column="1"
                                        Grid.ColumnSpan="2"
                                        Margin="0,8,0,0">
                                <ProgressBar Value="{Binding ProgressValue}" />
                                <DockPanel Margin="0,6,0,0">
                                    <TextBlock DockPanel.Dock="Left"
                                               Style="{StaticResource HelperTextStyle}"
                                               Text="{Binding ProgressText}" />
                                    <TextBlock DockPanel.Dock="Right"
                                               HorizontalAlignment="Right"
                                               FontWeight="SemiBold"
                                               Text="{Binding ProgressPercentLabel}" />
                                </DockPanel>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- Command + Log -->
        <Border Grid.Row="4"
                Style="{StaticResource PanelCardStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="12" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0">
                    <TextBlock DockPanel.Dock="Left"
                               Style="{StaticResource SectionTitleTextStyle}"
                               Text="Command And Logs" />
                    <TextBlock DockPanel.Dock="Right"
                               Margin="12,2,0,0"
                               Style="{StaticResource HelperTextStyle}"
                               Text="{Binding SelectedJobTitle}" />
                </DockPanel>

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="1.25*" />
                    </Grid.ColumnDefinitions>

                    <TextBox Grid.Column="0"
                             IsReadOnly="True"
                             Text="{Binding SelectedJobCommandPreview, Mode=OneWay}"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto" />
                    <TextBox x:Name="LogTextBox"
                             Grid.Column="2"
                             AcceptsReturn="True"
                             IsReadOnly="True"
                             Text="{Binding SelectedJobLogOutput, Mode=OneWay}"
                             TextChanged="LogTextBox_TextChanged"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto" />
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>

<UserControl x:Class="BlenderToolbox.Tools.LazyFrameRename.Views.LazyFrameRenameView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Style="{StaticResource PanelCardStyle}">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionTitleTextStyle}"
                               Text="Rename Mode" />
                    <TextBlock Margin="0,6,0,0"
                               Style="{StaticResource HelperTextStyle}"
                               Text="Manual mode targets specific folders. Subfolders mode processes every immediate child folder of a parent directory."
                               />

                    <StackPanel Margin="0,14,0,0">
                        <RadioButton Content="Select folders manually"
                                     GroupName="Mode"
                                     IsChecked="{Binding IsManualMode, Mode=OneWay}"
                                     Command="{Binding SetManualModeCommand}" />
                        <RadioButton Margin="0,10,0,0"
                                     Content="Process all immediate subfolders"
                                     GroupName="Mode"
                                     IsChecked="{Binding IsSubfoldersMode, Mode=OneWay}"
                                     Command="{Binding SetSubfoldersModeCommand}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Grid.Row="1"
                    Margin="0,12,0,0"
                    Style="{StaticResource PanelCardStyle}">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionTitleTextStyle}"
                               Text="Folders" />

                    <StackPanel Margin="0,14,0,0"
                                Visibility="{Binding IsSubfoldersMode, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBlock Style="{StaticResource HelperTextStyle}"
                                   Text="Choose the parent folder whose immediate subfolders should be processed."
                                   />
                        <Grid Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBox Grid.Column="0"
                                     Margin="0,0,12,0"
                                     Text="{Binding ParentFolder, UpdateSourceTrigger=PropertyChanged}" />
                            <Button Grid.Column="1"
                                    MinWidth="92"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Command="{Binding BrowseParentFolderCommand}"
                                    Content="Browse" />
                        </Grid>
                    </StackPanel>

                    <StackPanel Margin="0,14,0,0"
                                Visibility="{Binding IsManualMode, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBlock Style="{StaticResource HelperTextStyle}"
                                   Text="Add one or more folders and rename the files inside each selected folder."
                                   />

                        <ItemsControl Margin="0,12,0,0"
                                      ItemsSource="{Binding ManualFolders}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <TextBox Grid.Column="0"
                                                 Margin="0,0,12,0"
                                                 Text="{Binding Path, UpdateSourceTrigger=PropertyChanged}" />
                                        <Button Grid.Column="1"
                                                Margin="0,0,10,0"
                                                MinWidth="92"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Command="{Binding DataContext.BrowseFolderCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Content="Browse" />
                                        <Button Grid.Column="2"
                                                MinWidth="92"
                                                Style="{StaticResource DangerButtonStyle}"
                                                Command="{Binding DataContext.RemoveFolderCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Content="Remove" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Button HorizontalAlignment="Left"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Command="{Binding AddFolderCommand}"
                                Content="+ Add folder" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Grid.Row="2"
                    Margin="0,12,0,0"
                    Style="{StaticResource PanelCardStyle}">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionTitleTextStyle}"
                               Text="Settings" />

                    <Grid Margin="0,16,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   Grid.Column="0"
                                   Margin="0,8,0,0"
                                   Style="{StaticResource FieldLabelTextStyle}"
                                   Text="Frame name" />
                        <StackPanel Grid.Row="0"
                                    Grid.Column="1">
                            <TextBox Text="{Binding FrameName, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Margin="0,8,0,0"
                                       Style="{StaticResource HelperTextStyle}"
                                       Text="Leave blank to keep the original prefix."
                                       />
                        </StackPanel>

                        <TextBlock Grid.Row="1"
                                   Grid.Column="0"
                                   Margin="0,22,0,0"
                                   Style="{StaticResource FieldLabelTextStyle}"
                                   Text="Frame digits" />
                        <StackPanel Grid.Row="1"
                                    Grid.Column="1"
                                    Margin="0,14,0,0">
                            <RadioButton Content="Auto-detect from the first file"
                                         GroupName="Digits"
                                         IsChecked="{Binding IsDigitsAuto, Mode=OneWay}"
                                         Command="{Binding EnableAutoDigitsCommand}" />
                            <RadioButton Margin="0,10,0,0"
                                         Content="Use manual digit count"
                                         GroupName="Digits"
                                         IsChecked="{Binding IsManualDigitsMode, Mode=OneWay}"
                                         Command="{Binding EnableManualDigitsCommand}" />
                            <TextBox Width="88"
                                     Margin="0,12,0,0"
                                     HorizontalAlignment="Left"
                                     IsEnabled="{Binding IsManualDigitsMode}"
                                     Text="{Binding DigitsValue, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>

                        <TextBlock Grid.Row="2"
                                   Grid.Column="1"
                                   Margin="0,20,0,0"
                                   Style="{StaticResource StatusMessageTextStyle}"
                                   Tag="{Binding StatusTone}"
                                   Text="{Binding StatusMessage}"
                                   />
                    </Grid>
                </StackPanel>
            </Border>

            <Grid Grid.Row="3"
                  Margin="0,12,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           VerticalAlignment="Center"
                           Style="{StaticResource HelperTextStyle}"
                           Text="The start frame number is preserved and numbering is compacted without gaps." />
                <Button Grid.Column="2"
                        MinWidth="180"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Command="{Binding RenameFilesCommand}"
                        Content="Rename files" />
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>
